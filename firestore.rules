rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net (Default Deny Catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.updatedAt is int 
        && data.updatedAt <= request.time.toMillis()
        && (data.email == null || (data.email is string && data.email.size() <= 256))
        && (data.permissions == null || data.permissions is list)
        && (data.voiceInteractions == null || data.voiceInteractions is list)
        && (data.chatHistory == null || data.chatHistory is list)
        && (data.userLocation == null || data.userLocation is map)
        && (incoming().keys().hasAll(['updatedAt']) && incoming().keys().size() <= 7);
    }

    // Users Collection rules
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId) && isValidId(userId);
      allow create: if isSignedIn() && isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow delete: if false;
    }
  }
}
